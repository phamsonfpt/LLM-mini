# System Configuration
RAG_DATA_DIR=data
RAG_STORAGE_DIR=storage/qdrant
RAG_BM25_DIR=storage/bm25
RAG_QDRANT_COLLECTION=rag_chunks

# Chunking & Retrieval Parameters
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5

# Embedding Configuration
# Vietnamese/English embedding model: GreenNode/GreenNode-Embedding-Large-VN-Mixed-V1
# Or small/fast fallback: sentence-transformers/all-MiniLM-L6-v2
RAG_EMBEDDING_MODEL=keepitreal/vietnamese-sbert

# LLM Providers Configuration
# Supported: gemini, hf_local
RAG_LLM_PROVIDER=hf_local
RAG_LLM_TEMPERATURE=0.1

# Google Gemini API Config
GOOGLE_API_KEY=your-api-key-here

# Learning limits
RAG_SUMMARIZE_BATCH_SIZE=10
RAG_SUMMARIZE_RETRIEVAL_K=12
RAG_GENERATION_RETRIEVAL_K=16
RAG_QUIZ_DEFAULT_COUNT=8
RAG_FLASHCARDS_DEFAULT_COUNT=15

# API Config
RAG_API_URL=http://localhost:8000

# --- Local Semantic Cache ---
RAG_CACHE_TTL=3600
RAG_CACHE_SIMILARITY_THRESHOLD=0.92

# --- Session Memory ---
RAG_SESSION_MAX_MESSAGES=20

# --- Hybrid Search & Reranking ---
RAG_HYBRID_INITIAL_K=15
RAG_HYBRID_RERANK_K=5
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_BM25_TOP_K=15

# --- Stream Batching ---
RAG_STREAM_BUFFER_MS=50

# --- Observability ---
RAG_ENABLE_PROMETHEUS=true
RAG_ENABLE_LANGSMITH=false
RAG_LANGSMITH_API_KEY=
RAG_LANGSMITH_PROJECT=simple-notebooklm

